
{
  "app-id": "com.bongo.GameManager",
  "runtime": "org.gnome.Platform",
  "runtime-version": "46",
  "sdk": "org.gnome.Sdk",
  "command": "game-manager",

  "modules": [
    {
      "name": "game",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 run.sh /app/bin/game-manager",
        "cp -r src /app/src"
      ],
      "sources": [
        { "type": "dir", "path": "src" },
        { "type": "file", "path": "run.sh" }
      ]
    }
  ],

  "finish-args": [
    "--share=network",
    "--filesystem=home",
    "--socket=wayland",
    "--socket=x11"
  ]
}
